# ─────────────────────────────────────────────────────────────
# EchelonX Backend — Environment Variable Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development          # development | production
# Set to 1 when running behind nginx/load balancer in production
TRUST_PROXY=

# ── Frontend origin (used for CORS and email links) ───────────
FRONTEND_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=echelonx
DB_USER=postgres
DB_PASSWORD=<your_db_password>

# SSL for DB (production only)
# DB_SSL_REJECT_UNAUTHORIZED=true
# DB_SSL_CA=/path/to/ca-cert.pem

# ── JWT Secrets ───────────────────────────────────────────────
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Use DIFFERENT values for each secret.
JWT_SECRET=<replace_with_64_byte_random_hex>
JWT_REFRESH_SECRET=<replace_with_different_64_byte_random_hex>

# ── SMTP (email verification + password reset) ────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false             # true for port 465
SMTP_USER=<your_smtp_user>
SMTP_PASS=<your_smtp_password>

# ── External APIs ─────────────────────────────────────────────
# Get a free FRED key at: https://fred.stlouisfed.org/docs/api/api_key.html
# Required for US data ingestion. Must NOT be set to "demo" in production.
FRED_API_KEY=<your_fred_api_key>

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info                # error | warn | info | debug

# ── Rate limits (all windows in milliseconds) ─────────────────
# Auth routes
RATE_LOGIN_WINDOW_MS=900000       # 15 min
RATE_LOGIN_MAX=5
RATE_REGISTER_WINDOW_MS=3600000   # 1 hr
RATE_REGISTER_MAX=5
RATE_RESET_WINDOW_MS=3600000      # 1 hr
RATE_RESET_MAX=5

# General authenticated API
RATE_API_WINDOW_MS=60000          # 1 min
RATE_API_MAX=200

# Read-heavy endpoints (historical, dashboard, correlation)
RATE_READ_WINDOW_MS=60000         # 1 min
RATE_READ_MAX=120

# Compute-heavy endpoints
RATE_SIMULATION_WINDOW_MS=60000   # 1 min
RATE_SIMULATION_MAX=10
RATE_BACKTEST_WINDOW_MS=60000     # 1 min
RATE_BACKTEST_MAX=10
RATE_INGEST_WINDOW_MS=600000      # 10 min
RATE_INGEST_MAX=5
RATE_CALIBRATION_WINDOW_MS=600000 # 10 min
RATE_CALIBRATION_MAX=5
RATE_COUNTRY_ADD_WINDOW_MS=3600000 # 1 hr
RATE_COUNTRY_ADD_MAX=10
RATE_REFRESH_WINDOW_MS=600000     # 10 min
RATE_REFRESH_MAX=5
